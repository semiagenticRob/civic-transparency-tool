                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "“The intersection at Garrison and 80th has been a near-miss every weekday morning since the school-zone signage was changed. I'm asking council to put it on a traffic-study agenda before the next school year.”",
                          "lineHeight": 1.4,
                          "fontFamily": "Playfair Display",
