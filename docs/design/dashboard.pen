                          "layout": "vertical",
                          "gap": 24,
                          "padding": 24,
                          "children": [
                            {
                              "type": "frame",
                              "id": "N6EWIs",
                              "name": "q1",
                              "width": "fill_container",
                              "stroke": {
                                "thickness": {
                                  "left": 4
                                },
                                "fill": "#3b5bdb"
                              },
                              "layout": "vertical",
                              "gap": 8,
                              "padding": [
                                4,
                                0,
                                4,
                                16
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "saS0w",
                                  "fill": "#1f2937",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "\"I would very much like to see the findings of the first investigation to be shared prior to the opening of a new investigation. So I will not be supporting this motion.\"",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal",
                                  "fontStyle": "italic"
                                },
                                {
                                  "type": "frame",
                                  "id": "NugFo",
                                  "name": "q1Meta",
                                  "width": "fill_container",
                                  "gap": 12,
                                  "justifyContent": "space_between",
                                  "alignItems": "center",
                                  "children": [
                                    {
                                      "type": "text",
                                      "id": "L71USw",
                                      "fill": "#2f4ac7",
                                      "content": "— Michael Griffith",
                                      "fontFamily": "Inter",
                                      "fontSize": 12,
                                      "fontWeight": "600"
                                    },
                                    {
                                      "type": "text",
                                      "id": "xa7bG",
                                      "fill": "#9ca3af",
                                      "content": "▶ Watch",
                                      "fontFamily": "Inter",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    }
                                  ]
                                },
                                {
                                  "type": "text",
                                  "id": "cHw8W",
                                  "fill": "#6b7280",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Griffith voted No on the second ethics inquiry, calling for findings of the still-pending first investigation to be released first.",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Inter",
                                  "fontSize": 12,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "hkd84",
                              "name": "q2",
                              "width": "fill_container",
                              "stroke": {
                                "thickness": {
                                  "left": 4
                                },
                                "fill": "#3b5bdb"
                              },
                              "layout": "vertical",
                              "gap": 8,
                              "padding": [
                                4,
                                0,
                                4,
                                16
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "MPZaB",
                                  "fill": "#1f2937",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "\"We have this great opportunity to look seriously at option 2 — we would be one of the lowest cities offering composting service and still be able to add the service without adding cost to our customers.\"",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal",
                                  "fontStyle": "italic"
                                },
                                {
                                  "type": "frame",
                                  "id": "m6Cxjb",
                                  "name": "q2Meta",
                                  "width": "fill_container",
                                  "gap": 12,
                                  "justifyContent": "space_between",
                                  "alignItems": "center",
                                  "children": [
                                    {
                                      "type": "text",
                                      "id": "KaM74",
                                      "fill": "#2f4ac7",
                                      "content": "— Randy Moorman (Mayor Pro Tem)",
                                      "fontFamily": "Inter",
                                      "fontSize": 12,
                                      "fontWeight": "600"
                                    },
                                    {
                                      "type": "text",
                                      "id": "BSseb",
                                      "fill": "#9ca3af",
                                      "content": "▶ Watch",
                                      "fontFamily": "Inter",
                                      "fontSize": 12,
                                      "fontWeight": "normal"
                                    }
                                  ]
                                },
                                {
                                  "type": "text",
                                  "id": "SeoIV",
                                  "fill": "#6b7280",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Moorman pushed for citywide opt-out composting funded by the incoming EPR recycling refund. Council ultimately favored the staff's slower stepwise approach.",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Inter",
                                  "fontSize": 12,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "A3aHoI",
                              "name": "q3",
                              "width": "fill_container",
                              "stroke": {
                                "thickness": {
                                  "left": 4
                                },
                                "fill": "#3b5bdb"
                              },
                              "layout": "vertical",
                              "gap": 8,
                              "padding": [
                                4,
                                0,
                                4,
                                16
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "R3Y7n",
                                  "fill": "#1f2937",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "\"This is also about wildfire defense. People will be able to reduce slash, leaves, sticks and other organics in an accessible way. You are only as safe as your neighbor.\"",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal",
                                  "fontStyle": "italic"
                                },
                                {
                                  "type": "frame",
                                  "id": "QXaWP",
                                  "name": "q3Meta",
                                  "width": "fill_container",
                                  "gap": 12,
                                  "justifyContent": "space_between",
                                  "alignItems": "center",
                                  "children": [
                                    {
                                      "type": "text",
                                      "id": "TQc4x",
                                      "fill": "#2f4ac7",
                                      "content": "— Shawna Ambrose",
                                      "fontFamily": "Inter",
                                      "fontSize": 12,
                                      "fontWeight": "600"
                                    },
