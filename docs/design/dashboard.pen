                      "content": "THE FOUR OPTIONS · AT A GLANCE",
                      "fontFamily": "Inter",
                      "fontSize": 11,
                      "fontWeight": "700",
                      "letterSpacing": 2
                    },
                    {
                      "type": "frame",
                      "id": "n5amK",
                      "name": "opt1",
                      "width": "fill_container",
                      "stroke": {
