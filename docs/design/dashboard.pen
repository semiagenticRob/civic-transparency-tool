                              "content": "NO · 2",
                              "fontFamily": "Inter",
                              "fontSize": 11,
                              "fontWeight": "700",
                              "letterSpacing": 1.5
                            },
                            {
                              "type": "text",
                              "id": "w979PH",
                              "fill": "#111827",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Lovisone  ·  Griffith",
                              "fontFamily": "Newsreader",
                              "fontSize": 15,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
