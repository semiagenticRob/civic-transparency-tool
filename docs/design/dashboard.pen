                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "cFKm0",
                              "fill": "#9ca3af",
                              "content": "EXCUSED",
                              "fontFamily": "Inter",
                              "fontSize": 11,
                              "fontWeight": "700",
                              "letterSpacing": 1.5
                            },
                            {
                              "type": "text",
                              "id": "lyiLB",
