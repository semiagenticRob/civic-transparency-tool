                      "fill": "#9ca3af",
                      "content": "THE FOUR OPTIONS · AT A GLANCE",
                      "fontFamily": "Inter",
                      "fontSize": 11,
                      "fontWeight": "700",
                      "letterSpacing": 2
                    },
                    {
                      "type": "frame",
                      "id": "JTngd",
                      "name": "opt1",
