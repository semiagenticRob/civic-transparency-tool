                              "children": [
                                {
                                  "type": "text",
                                  "id": "dBkzI",
                                  "fill": "#3b5bdb",
                                  "content": "OPTION 1",
                                  "fontFamily": "Inter",
                                  "fontSize": 11,
                                  "fontWeight": "700",
                                  "letterSpacing": 2
                                },
                                {
                                  "type": "text",
                                  "id": "oYOdl",
                                  "fill": "#111827",
                                  "content": "Subscription / opt-in",
                                  "fontFamily": "Playfair Display",
                                  "fontSize": 18,
                                  "fontWeight": "700"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "yHojL",
                              "fill": "#6b7280",
                              "content": "$15–20 / mo",
                              "fontFamily": "Newsreader",
                              "fontSize": 14,
                              "fontWeight": "600"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "dZdT4",
                          "fill": "#374151",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Residents who want composting opt in and pay individually. Republic requires a minimum 3,000 households to sign up before the program can launch — and inefficient \"chaser\" routes drive the per-customer cost up.",
                          "lineHeight": 1.6,
                          "fontFamily": "Newsreader",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "MdJD1",
                      "name": "opt2",
