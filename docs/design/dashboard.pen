                      "id": "G00AQu",
                      "fill": "#5b21b6",
                      "content": "SOURCES & RESOURCES",
                      "fontFamily": "Inter",
                      "fontSize": 10,
                      "fontWeight": "700",
                      "letterSpacing": 2
                    },
                    {
                      "type": "text",
                      "id": "cmwIA",
                      "fill": "#2f4ac7",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "↗ Sustainable Energy Plan (2021, full PDF) · 2024 Community GHG Inventory · Solar carport ROI memo · Xcel Colorado generation mix (CO PUC) · CDPHE EV adoption dashboard · 2022 building code update text · Watch the full briefing from 1:42:08",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 12,
                      "fontWeight": "600",
                      "letterSpacing": 0.3
                    }
                  ]
                }
              ]
            },
