              ]
            },
            {
              "type": "frame",
              "id": "Kl49z",
              "name": "Lead Story",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 18,
              "children": [
                {
                  "type": "text",
                  "id": "x19ix",
                  "fill": "#3b5bdb",
                  "content": "WORKSHOP TOPIC · SOLID WASTE & COMPOSTING",
                  "fontFamily": "Inter",
                  "fontSize": 11,
                  "fontWeight": "700",
                  "letterSpacing": 2
                },
                {
                  "type": "text",
                  "id": "MCWzS",
                  "fill": "#111827",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Four directions on composting — and the recycling refund that could pay for it",
                  "lineHeight": 1.15,
                  "fontFamily": "Playfair Display",
                  "fontSize": 34,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "XVDB5",
                  "fill": "#374151",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "This is a workshop, not a vote. Council heard four staff-prepared options for how (or whether) Arvada offers curbside organics composting, and weighed them against an incoming EPR recycling refund that will reduce customer bills this fall. The point of the night was to give staff direction on which option to develop further. No formal decision was made.",
                  "lineHeight": 1.65,
                  "fontFamily": "Newsreader",
                  "fontSize": 18,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "m07cK",
                  "name": "Pull Quote 1",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "padding": [
                    16,
                    40
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "cjS0O",
                      "fill": "#111e5c",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "“This is a workshop. We don't vote here — but the direction we give staff tonight is what shows up on the business-meeting agenda next.”",
                      "lineHeight": 1.35,
                      "fontFamily": "Playfair Display",
                      "fontSize": 26,
                      "fontWeight": "normal",
                      "fontStyle": "italic"
                    },
                    {
                      "type": "text",
                      "id": "G8P8v",
                      "fill": "#6b7280",
                      "content": "— Mayor Lauren Simpson, opening the discussion",
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "600",
                      "letterSpacing": 1
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "AKqO9",
                  "fill": "#374151",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "What happens next: staff will return with a refined recommendation. A formal decision — including any rate-and-fee changes — would be made at a future City Council Business Meeting, where public comment is taken.",
                  "lineHeight": 1.65,
                  "fontFamily": "Newsreader",
                  "fontSize": 17,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "nqqMj",
              "name": "divider1",
              "width": "fill_container",
              "height": 1,
              "fill": "#e5e7eb",
              "justifyContent": "center"
            },
            {
              "type": "frame",
              "id": "AMU4S",
              "name": "Workshop Section",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 18,
              "children": [
                {
                  "type": "text",
                  "id": "ZwT4L",
                  "fill": "#3b5bdb",
                  "content": "WORKSHOP · SOLID WASTE & COMPOSTING",
                  "fontFamily": "Inter",
                  "fontSize": 11,
                  "fontWeight": "700",
                  "letterSpacing": 2
                },
                {
                  "type": "text",
                  "id": "YdjLG",
                  "fill": "#111827",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "A fight over composting — and what the recycling refund could buy",
                  "lineHeight": 1.2,
                  "fontFamily": "Playfair Display",
                  "fontSize": 30,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "rWFKK",
                  "fill": "#374151",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Council reached easy informal consensus on three of the four directions staff brought forward: pass through Republic's contracted increases, raise the city program fee a nickel (from $1.69 to $1.74), and keep the $1.06 enterprise fee in place to comply with reserve policy. The disagreement was over composting.",
                  "lineHeight": 1.65,
                  "fontFamily": "Newsreader",
                  "fontSize": 17,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "PCzIR",
                  "name": "Options at a glance",
                  "width": "fill_container",
                  "fill": "#f8f5ed",
                  "stroke": {
                    "thickness": {
                      "top": 2,
                      "bottom": 2
                    },
                    "fill": "#111e5c"
                  },
                  "layout": "vertical",
