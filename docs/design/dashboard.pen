                  "gap": 8,
                  "padding": [
                    20,
                    24
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "pLmhF",
                      "fill": "#9ca3af",
                      "content": "THE MOTION",
                      "fontFamily": "Inter",
                      "fontSize": 10,
                      "fontWeight": "700",
                      "letterSpacing": 2
                    },
