            {
              "type": "frame",
              "id": "HP7qH",
              "name": "Public Hearings",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 18,
              "children": [
                {
                  "type": "text",
                  "id": "mPQvn",
                  "fill": "#3b5bdb",
                  "content": "PUBLIC HEARINGS",
                  "fontFamily": "Inter",
                  "fontSize": 11,
                  "fontWeight": "700",
                  "letterSpacing": 2
                },
                {
                  "type": "text",
                  "id": "wmgJa",
                  "fill": "#111827",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Public hearing on a second ethics inquiry into Councilmember Davis",
                  "lineHeight": 1.15,
                  "fontFamily": "Playfair Display",
                  "fontSize": 34,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "FQSgH",
                  "fill": "#374151",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Council opened the night's only contested public hearing to consider authorizing an outside investigator and outside counsel to look into a second alleged ethics violation involving Councilmember Sharon Davis. The first investigation, authorized February 3, has not yet released findings. Davis was excused for the hearing and the vote.",
                  "lineHeight": 1.65,
                  "fontFamily": "Newsreader",
                  "fontSize": 18,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "t2i8ca",
                  "name": "phStaff",
                  "width": "fill_container",
                  "fill": "#fefdf8",
                  "stroke": {
                    "thickness": {
                      "top": 1,
                      "bottom": 1
                    },
                    "fill": "#e5e7eb"
                  },
                  "layout": "vertical",
                  "gap": 10,
                  "padding": [
                    16,
                    18
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "AwbPr",
                      "fill": "#3b5bdb",
                      "content": "FROM THE CITY",
                      "fontFamily": "Inter",
                      "fontSize": 11,
                      "fontWeight": "700",
                      "letterSpacing": 2
                    },
                    {
                      "type": "frame",
                      "id": "RalLX",
                      "name": "phStaffQuote",
                      "width": "fill_container",
                      "fill": "#f8f5ed",
                      "cornerRadius": 4,
                      "stroke": {
                        "thickness": {
                          "left": 3
                        },
                        "fill": "#111e5c"
                      },
                      "layout": "vertical",
                      "gap": 6,
                      "padding": [
                        10,
                        14
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "fBMZH",
                          "fill": "#111e5c",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "“Releasing the first investigation's findings now could have the effect of impacting the overall process. Handling both probes together is the better approach from a due-process perspective.”",
                          "lineHeight": 1.4,
                          "fontFamily": "Playfair Display",
                          "fontSize": 17,
                          "fontWeight": "normal",
                          "fontStyle": "italic"
                        },
                        {
                          "type": "text",
                          "id": "G2ygUJ",
                          "fill": "#6b7280",
                          "content": "— City Attorney Mark Hoffman · 1:22:14 in the meeting",
                          "fontFamily": "Inter",
                          "fontSize": 11,
                          "fontWeight": "600",
                          "letterSpacing": 0.3
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "DHhIl",
                  "name": "phOutside",
                  "width": "fill_container",
                  "fill": "#fefdf8",
                  "stroke": {
                    "thickness": {
                      "top": 1,
                      "bottom": 1
                    },
                    "fill": "#e5e7eb"
                  },
                  "layout": "vertical",
                  "gap": 10,
                  "padding": [
                    16,
                    18
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "GbVJk",
                      "fill": "#3b5bdb",
                      "content": "FROM OUTSIDE PARTIES",
                      "fontFamily": "Inter",
                      "fontSize": 11,
                      "fontWeight": "700",
                      "letterSpacing": 2
                    },
                    {
                      "type": "text",
                      "id": "I6yENF",
                      "fill": "#6b7280",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "No outside parties were heard during this hearing. The matter is an internal council inquiry and does not involve an applicant, attorney for an outside party, or expert witness. This section is omitted when no outside parties appear at a hearing.",
                      "lineHeight": 1.6,
                      "fontFamily": "Newsreader",
                      "fontSize": 13,
                      "fontWeight": "normal",
                      "fontStyle": "italic"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "HMIMt",
                  "name": "phCouncil",
                  "width": "fill_container",
                  "fill": "#fefdf8",
                  "stroke": {
                    "thickness": {
                      "top": 1,
                      "bottom": 1
                    },
                    "fill": "#e5e7eb"
                  },
                  "layout": "vertical",
                  "gap": 10,
                  "padding": [
                    16,
                    18
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "S5TtV",
                      "fill": "#3b5bdb",
                      "content": "FROM COUNCIL",
                      "fontFamily": "Inter",
                      "fontSize": 11,
                      "fontWeight": "700",
                      "letterSpacing": 2
                    },
                    {
                      "type": "frame",
                      "id": "ZMaAb",
                      "name": "phCouncilQ1",
                      "width": "fill_container",
                      "fill": "#f8f5ed",
                      "cornerRadius": 4,
                      "stroke": {
                        "thickness": {
                          "left": 3
                        },
                        "fill": "#111e5c"
                      },
                      "layout": "vertical",
                      "gap": 6,
                      "padding": [
                        10,
                        14
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "OGdLp",
                          "fill": "#111e5c",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "“I would very much like to see the findings of the first investigation to be shared prior to the opening of a new investigation. So I will not be supporting this motion.”",
                          "lineHeight": 1.4,
                          "fontFamily": "Playfair Display",
                          "fontSize": 17,
                          "fontWeight": "normal",
                          "fontStyle": "italic"
                        },
                        {
                          "type": "text",
                          "id": "zVzNB",
                          "fill": "#6b7280",
                          "content": "— Councilmember Michael Griffith · 1:24:01 · voted no",
                          "fontFamily": "Inter",
                          "fontSize": 11,
                          "fontWeight": "600",
                          "letterSpacing": 0.3
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "ZBpAs",
                      "name": "phCouncilQ2",
                      "width": "fill_container",
                      "fill": "#f8f5ed",
                      "cornerRadius": 4,
                      "stroke": {
                        "thickness": {
                          "left": 3
                        },
                        "fill": "#111e5c"
                      },
                      "layout": "vertical",
                      "gap": 6,
                      "padding": [
                        10,
                        14
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "giuDr",
                          "fill": "#111e5c",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "“We need that trust built between the two investigations. Doing them in sequence — not parallel — is how we get there.”",
                          "lineHeight": 1.4,
                          "fontFamily": "Playfair Display",
                          "fontSize": 17,
                          "fontWeight": "normal",
                          "fontStyle": "italic"
                        },
                        {
                          "type": "text",
                          "id": "B9UiSX",
                          "fill": "#6b7280",
                          "content": "— Councilmember Rebecka Lovisone · 1:25:33 · voted no",
                          "fontFamily": "Inter",
                          "fontSize": 11,
                          "fontWeight": "600",
                          "letterSpacing": 0.3
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "gnmCp",
                      "name": "phCouncilQ3",
                      "width": "fill_container",
                      "fill": "#f8f5ed",
                      "cornerRadius": 4,
                      "stroke": {
                        "thickness": {
                          "left": 3
                        },
                        "fill": "#111e5c"
                      },
                      "layout": "vertical",
                      "gap": 6,
                      "padding": [
                        10,
                        14
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "X6qOlk",
                          "fill": "#111e5c",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "“I will follow the city attorney's legal advice on this. The parallel approach protects due process for everyone involved — including Councilmember Davis.”",
                          "lineHeight": 1.4,
                          "fontFamily": "Playfair Display",
                          "fontSize": 17,
                          "fontWeight": "normal",
                          "fontStyle": "italic"
                        },
                        {
                          "type": "text",
                          "id": "caCBx",
                          "fill": "#6b7280",
                          "content": "— Mayor Lauren Simpson · 1:26:48 · voted yes",
                          "fontFamily": "Inter",
                          "fontSize": 11,
                          "fontWeight": "600",
                          "letterSpacing": 0.3
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "pyQkc",
                  "name": "phPublic",
                  "width": "fill_container",
                  "fill": "#fefdf8",
                  "stroke": {
                    "thickness": {
                      "top": 1,
                      "bottom": 1
                    },
                    "fill": "#e5e7eb"
                  },
                  "layout": "vertical",
                  "gap": 10,
                  "padding": [
                    16,
                    18
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "AlDUF",
                      "fill": "#3b5bdb",
                      "content": "FROM THE PUBLIC AT THE HEARING",
                      "fontFamily": "Inter",
                      "fontSize": 11,
                      "fontWeight": "700",
                      "letterSpacing": 2
                    },
                    {
                      "type": "frame",
                      "id": "g4lq4",
                      "name": "phPublicQ",
                      "width": "fill_container",
                      "fill": "#f8f5ed",
                      "cornerRadius": 4,
                      "stroke": {
                        "thickness": {
                          "left": 3
                        },
                        "fill": "#111e5c"
                      },
                      "layout": "vertical",
                      "gap": 6,
                      "padding": [
                        10,
                        14
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "c9k7H",
                          "fill": "#111e5c",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "“As a constituent, I support transparency on both inquiries. I'd ask council to commit to releasing the first investigation's findings as soon as the city attorney clears it.”",
                          "lineHeight": 1.4,
                          "fontFamily": "Playfair Display",
                          "fontSize": 17,
                          "fontWeight": "normal",
                          "fontStyle": "italic"
                        },
                        {
                          "type": "text",
                          "id": "TtLAH",
                          "fill": "#6b7280",
                          "content": "— Daniel Yoon, Arvada resident (District 1) · 1:21:02 in the meeting",
