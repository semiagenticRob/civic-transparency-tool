                              "alignItems": "center",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "Q3lPYp",
                                  "fill": "#3b5bdb",
                                  "content": "OPTION 1",
                                  "fontFamily": "Inter",
                                  "fontSize": 11,
                                  "fontWeight": "700",
                                  "letterSpacing": 2
                                },
                                {
                                  "type": "text",
                                  "id": "p9yps",
                                  "fill": "#111827",
                                  "content": "Subscription / opt-in",
