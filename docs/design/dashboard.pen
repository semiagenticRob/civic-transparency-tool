                              "content": "Circular Action Alliance is processing applications statewide; Arvada filed before the April 13 deadline.",
                              "lineHeight": 1.5,
                              "fontFamily": "Newsreader",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    }
                  ]
