                          "id": "HlXyI",
                          "name": "nn2",
                          "width": "fill_container",
                          "stroke": {
                            "thickness": {
                              "bottom": 1
                            },
                            "fill": "#e5e7eb"
                          },
                          "layout": "vertical",
                          "gap": 4,
                          "padding": [
                            12,
                            0
                          ],
