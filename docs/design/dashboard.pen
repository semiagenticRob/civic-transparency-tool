            },
            {
              "type": "frame",
              "id": "yXEKd",
              "name": "Lead Story",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 18,
              "children": [
                {
                  "type": "text",
                  "id": "vfvgI",
                  "fill": "#3b5bdb",
                  "content": "LEAD STORY · SPECIAL SESSION",
                  "fontFamily": "Inter",
                  "fontSize": 11,
                  "fontWeight": "700",
                  "letterSpacing": 2
                },
                {
                  "type": "text",
                  "id": "vhNJt",
                  "fill": "#111827",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Council authorizes a second ethics probe into Davis, 4–2",
                  "lineHeight": 1.15,
                  "fontFamily": "Playfair Display",
                  "fontSize": 34,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "HWdzz",
                  "fill": "#374151",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Before opening Tuesday's solid-waste workshop, council voted 4–2 to authorize an outside investigator and outside counsel to look into a second alleged ethics violation involving Councilmember Sharon Davis. Davis was excused for the vote. The first investigation, authorized February 3, has not yet released findings — and that gap is exactly what councilmembers Rebecka Lovisone and Michael Griffith pointed to in voting no.",
                  "lineHeight": 1.65,
                  "fontFamily": "Newsreader",
                  "fontSize": 18,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "Wkp13",
                  "name": "Vote Block",
                  "width": "fill_container",
                  "fill": "#f8f5ed",
                  "stroke": {
                    "thickness": {
                      "left": 4
                    },
                    "fill": "#111e5c"
                  },
