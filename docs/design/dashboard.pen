                            {
                              "type": "text",
                              "id": "TGbIO",
                              "fill": "#111827",
                              "content": "Autopay finally arrives",
                              "fontFamily": "Newsreader",
                              "fontSize": 15,
                              "fontWeight": "700"
                            },
                            {
                              "type": "text",
                              "id": "w3sR5",
                              "fill": "#374151",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Republic Services rolls out credit-card autopay next week — first time the city's solid-waste customers have had the option.",
                              "lineHeight": 1.5,
                              "fontFamily": "Newsreader",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
