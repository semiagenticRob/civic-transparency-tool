{# Workshop newsletter — inline-CSS HTML for Beehiiv.
   Beehiiv strips <style>/<link>; every style is on the element. #}
<div style="font-family: 'Newsreader', Georgia, 'Times New Roman', serif; background: #fefdf8; color: #374151; max-width: 680px; margin: 0 auto; padding: 40px 24px;">

  {% include "_masthead.html.j2" %}

  {% set strip_bg = "#eef2ff" %}
  {% set strip_border = "#c7d2fe" %}
  {% set pill_bg = "#111e5c" %}
  {% set meeting_type_label = "CITY COUNCIL WORKSHOP" %}
  {% set purpose_blurb = analysis.meeting_purpose_blurb %}
  {% include "_purpose_strip.html.j2" %}

  {# ─── META LINE ──────────────────────────────────────────────── #}
  <div style="text-align: center; padding: 8px 0 32px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 1.5px; color: #6b7280;">
    WORKSHOP DISCUSSION · NO FORMAL VOTE
    {% if meeting_video_url %}
      &nbsp;·&nbsp;<a href="{{ meeting_video_url }}" style="color: #2f4ac7; text-decoration: none;">WATCH THE MEETING ↗</a>
    {% endif %}
  </div>

  {# ─── WORKSHOP TOPICS — each rendered as a standalone section ─── #}
  {% for topic in analysis.workshop_topics %}
  <div style="margin-bottom: 40px;">
    <div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 2px; color: #3b5bdb; margin-bottom: 12px;">
      WORKSHOP TOPIC · {{ topic.title|upper }}
    </div>
    {% if topic.tagline %}
    <h1 style="font-family: 'Playfair Display', Georgia, serif; font-size: 30px; font-weight: 700; line-height: 1.2; color: #111827; margin: 0 0 16px 0;">
      {{ topic.tagline }}
    </h1>
    {% endif %}
    {% if topic.lede %}
    <p style="font-family: 'Newsreader', Georgia, serif; font-size: 17px; line-height: 1.65; color: #374151; margin: 0 0 20px 0;">
      {{ topic.lede }}
    </p>
    {% endif %}

    {# Options at a glance #}
    {% if topic.options %}
    <div style="background: #f8f5ed; border-top: 2px solid #111e5c; border-bottom: 2px solid #111e5c; padding: 20px 24px; margin: 24px 0;">
      <div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 2px; color: #9ca3af; margin-bottom: 14px;">
        OPTIONS · AT A GLANCE
      </div>
      {% for opt in topic.options %}
      <div style="padding: 14px 0; {% if not loop.last %}border-bottom: 1px solid #d4cdb5;{% endif %}">
        <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 6px;">
          <span style="font-family: 'Newsreader', Georgia, serif; font-size: 16px; font-weight: 700; color: #111827;">
            Option {{ opt.number }} — {{ opt.label }}
          </span>
          {% if opt.cost %}
          <span style="font-family: -apple-system, sans-serif; font-size: 11px; font-weight: 600; color: #6b7280; letter-spacing: 0.5px;">
            {{ opt.cost }}
          </span>
          {% endif %}
        </div>
        {% if opt.summary %}
        <div style="font-family: 'Newsreader', Georgia, serif; font-size: 14px; color: #374151; line-height: 1.6;">
          {{ opt.summary }}
        </div>
        {% endif %}
        {% if opt.endorsement %}
        <div style="font-family: -apple-system, sans-serif; font-size: 11px; font-weight: 600; color: #2f4ac7; letter-spacing: 0.5px; margin-top: 4px;">
          {{ opt.endorsement }}
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {# Member Preferences — NOT a vote. Full council roster rendered (rows are
       precomputed in render_newsletter._build_workshop_topic_rows). Each row's
       status is one of aligned / off_menu / no_preference / absent and drives
       the LEANS TOWARD and IN THEIR OWN WORDS variants below.
       Table layout is fixed-width so long content can't starve neighbouring
       columns. Tables (not flex) for Outlook/Gmail compatibility. #}
    {% set rows = workshop_topic_rows.get(topic.title, []) %}
    {% if rows %}
    <div style="margin: 32px 0;">
      <div style="font-family: -apple-system, sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 2px; color: #3b5bdb; margin-bottom: 10px;">
        MEMBER PREFERENCES · NOT A VOTE
      </div>
      <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: 22px; font-weight: 700; line-height: 1.2; color: #111827; margin: 0 0 10px 0;">
        Where each councilmember leaned — in their own words
      </h2>
      <p style="font-family: 'Newsreader', Georgia, serif; font-size: 15px; line-height: 1.55; color: #6b7280; margin: 0 0 16px 0;">
        No vote was taken. Workshops examine topics, not decide them. The full council is shown below; members who proposed off-menu directions, did not weigh in, or were absent are flagged so silence is not read as agreement.
      </p>
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="border-collapse: collapse; border-top: 2px solid #111e5c; border-bottom: 2px solid #111e5c; table-layout: fixed;">
        <colgroup>
          <col style="width: 64px;">
          <col style="width: 28%;">
          <col style="width: 22%;">
          <col>
        </colgroup>
        <thead>
          <tr>
            <th colspan="2" style="text-align: left; padding: 10px 12px 8px 0; font-family: -apple-system, sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 2px; color: #9ca3af; border-bottom: 1px solid #e5e7eb;">COUNCILMEMBER</th>
            <th style="text-align: left; padding: 10px 12px 8px; font-family: -apple-system, sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 2px; color: #9ca3af; border-bottom: 1px solid #e5e7eb;">LEANS&nbsp;TOWARD</th>
            <th style="text-align: left; padding: 10px 0 8px 12px; font-family: -apple-system, sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 2px; color: #9ca3af; border-bottom: 1px solid #e5e7eb;">IN THEIR OWN WORDS</th>
          </tr>
        </thead>
        <tbody>
        {% for row in rows %}
        {% set m = row.member %}
        {% set is_absent = row.status == 'absent' %}
        <tr>
          {# Photo — dimmed when absent so the eye registers absence #}
          <td valign="top" style="padding: 16px 12px 16px 0; {% if not loop.last %}border-bottom: 1px solid #f3f4f6;{% endif %}">
            {% if m and m.photo_url %}
            <img src="{{ m.photo_url }}" width="48" height="48" alt="{{ row.name }}" style="width: 48px; height: 48px; border-radius: 50%; display: block; object-fit: cover;{% if is_absent %} opacity: 0.35;{% endif %}">
            {% endif %}
          </td>
          {# Name + meta — muted when absent #}
          <td valign="top" style="padding: 16px 12px 16px 0; {% if not loop.last %}border-bottom: 1px solid #f3f4f6;{% endif %}">
            <div style="font-family: 'Newsreader', Georgia, serif; font-size: 15px; font-weight: 700; color: {% if is_absent %}#9ca3af{% else %}#111827{% endif %}; line-height: 1.3;">
              {{ row.name }}
            </div>
            {% if m %}
            <div style="font-family: -apple-system, sans-serif; font-size: 12px; color: #9ca3af; line-height: 1.5; margin-top: 2px;">
              {{ m.title }}{% if m.district %} · {{ m.district }}{% endif %}
            </div>
            {% if m.phone %}
            <div style="font-family: -apple-system, sans-serif; font-size: 12px; color: #9ca3af; line-height: 1.5;">
              {{ m.phone }}
            </div>
            {% endif %}
            {% endif %}
          </td>
          {# LEANS TOWARD — four status variants #}
          <td valign="top" style="padding: 16px 12px; {% if not loop.last %}border-bottom: 1px solid #f3f4f6;{% endif %}">
            {% if row.status == 'aligned' %}
              <span style="font-family: -apple-system, sans-serif; font-size: 13px; font-weight: 700; color: #111e5c; letter-spacing: 0.3px; white-space: nowrap;">
                {{ row.option_preference }}
              </span>
            {% elif row.status == 'off_menu' %}
              <div style="font-family: -apple-system, sans-serif; font-size: 11px; font-weight: 700; color: #6b7280; letter-spacing: 1.2px; text-transform: uppercase; margin-bottom: 4px;">Off-menu</div>
              <div style="font-family: 'Newsreader', Georgia, serif; font-size: 13px; font-weight: 600; color: #374151; line-height: 1.4;">
                {{ row.off_menu_summary }}
              </div>
            {% elif row.status == 'no_preference' %}
              <span style="font-family: -apple-system, sans-serif; font-size: 12px; font-style: italic; color: #9ca3af; letter-spacing: 0.2px;">
                Did not weigh in
              </span>
            {% elif row.status == 'absent' %}
              <span style="font-family: -apple-system, sans-serif; font-size: 12px; font-style: italic; color: #9ca3af; letter-spacing: 0.2px;">
                Absent
              </span>
            {% endif %}
          </td>
          {# IN THEIR OWN WORDS — only for aligned + off_menu, em-dash otherwise #}
          <td valign="top" style="padding: 16px 0 16px 12px; {% if not loop.last %}border-bottom: 1px solid #f3f4f6;{% endif %}">
            {% if row.quote and row.quote.text %}
            <div style="font-family: 'Newsreader', Georgia, serif; font-size: 14px; font-style: italic; color: #374151; line-height: 1.55;">
              {% if row.quote.video_url %}<a href="{{ row.quote.video_url }}" style="color: inherit; text-decoration: none;">{% endif %}“{{ row.quote.text }}”{% if row.quote.video_url %}</a>{% endif %}
            </div>
            {% else %}
            <div style="font-family: -apple-system, sans-serif; font-size: 14px; color: #d1d5db; text-align: left;">—</div>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}

    {# What this informs #}
    {% if topic.feeds_into %}
    <div style="background: #fffbeb; border: 1px solid #fde68a; padding: 20px 24px; margin: 32px 0;">
      <div style="font-family: -apple-system, sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 2px; color: #b45309; margin-bottom: 6px;">
        WHAT THIS INFORMS
      </div>
      <div style="font-family: 'Newsreader', Georgia, serif; font-size: 15px; line-height: 1.6; color: #78350f;">
        {{ topic.feeds_into }}
      </div>
    </div>
    {% endif %}
  </div>
  {% endfor %}

  {% set schedule_link_label = "View upcoming City Council workshops" %}
  {% include "_footer.html.j2" %}

</div>
