{# Meeting-type purpose strip — verbatim blurb from arvadaco.gov.
   Context: meeting_type_label (str), purpose_blurb (str),
            strip_bg, strip_border, pill_bg (colors per meeting type). #}
<div style="display: block; margin: 24px 0; padding: 14px 18px; background: {{ strip_bg }}; border: 1px solid {{ strip_border }}; border-radius: 4px; font-family: 'Newsreader', Georgia, 'Times New Roman', serif;">
  <div style="display: inline-block; padding: 5px 12px; background: {{ pill_bg }}; border-radius: 999px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 1.5px; color: #fefdf8; vertical-align: middle;">
    {{ meeting_type_label }}
  </div>
  <span style="display: inline-block; margin-left: 12px; font-style: italic; font-size: 14px; color: #374151; line-height: 1.5; vertical-align: middle;">
    {{ purpose_blurb }}
  </span>
</div>
