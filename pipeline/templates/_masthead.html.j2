{# Masthead partial — used by all three meeting-type newsletters.
   Context: newsletter (dict), formatted_date (str). #}
<div style="text-align: center; padding-bottom: 24px; border-bottom: 3px solid #111e5c;">
  <div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 2px; color: #9ca3af; margin-bottom: 12px;">
    {{ formatted_date }}
  </div>
  <div style="font-family: 'Playfair Display', Georgia, 'Times New Roman', serif; font-size: 44px; font-weight: 800; letter-spacing: -1px; color: #111e5c; line-height: 1.1; margin-bottom: 8px;">
    {{ newsletter.name|upper }}
  </div>
  <div style="font-family: 'Newsreader', Georgia, 'Times New Roman', serif; font-style: italic; font-size: 15px; color: #6b7280;">
    {{ newsletter.tagline }}
  </div>
</div>
