{# Study Session newsletter — inline-CSS HTML for Beehiiv.
   Each briefing is a standalone full-style presentation. #}
<div style="font-family: 'Newsreader', Georgia, 'Times New Roman', serif; background: #fefdf8; color: #374151; max-width: 680px; margin: 0 auto; padding: 40px 24px;">

  {% include "_masthead.html.j2" %}

  {% set strip_bg = "#f5f3ff" %}
  {% set strip_border = "#c4b5fd" %}
  {% set pill_bg = "#5b21b6" %}
  {% set meeting_type_label = "CITY COUNCIL STUDY SESSION" %}
  {% set purpose_blurb = analysis.meeting_purpose_blurb %}
  {% include "_purpose_strip.html.j2" %}

  {# ─── META LINE ──────────────────────────────────────────────── #}
  <div style="text-align: center; padding: 8px 0 32px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 1.5px; color: #6b7280;">
    INFORMAL LEARNING SESSION · NO PUBLIC COMMENT
    {% if meeting_video_url %}
      &nbsp;·&nbsp;<a href="{{ meeting_video_url }}" style="color: #2f4ac7; text-decoration: none;">WATCH THE MEETING ↗</a>
    {% endif %}
  </div>

  {# ─── BRIEFINGS — each rendered identically as a standalone presentation ─── #}
  {% for briefing in analysis.briefings %}
  <div style="margin-bottom: 48px;">
    <div style="font-family: -apple-system, sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 2px; color: #3b5bdb; margin-bottom: 12px;">
      BRIEFING · {{ briefing.topic|upper }}
    </div>
    {% if briefing.topic %}
    <h1 style="font-family: 'Playfair Display', Georgia, serif; font-size: 30px; font-weight: 700; line-height: 1.15; color: #111827; margin: 0 0 16px 0;">
      {{ briefing.topic }}
    </h1>
    {% endif %}
    {% if briefing.presenter_name %}
    <div style="font-family: -apple-system, sans-serif; font-size: 12px; font-weight: 600; color: #6b7280; letter-spacing: 0.3px; margin-bottom: 20px;">
      Presented by {{ briefing.presenter_name }}{% if briefing.presenter_role %} · {{ briefing.presenter_role }}{% endif %}{% if briefing.duration_minutes %} · {{ briefing.duration_minutes }} minutes{% endif %}
    </div>
    {% endif %}

    {# Featured pull quote — first verbatim presenter quote #}
    {% set featured_quote = briefing.presenter_quotes[0] if briefing.presenter_quotes else None %}
    {% if featured_quote and featured_quote.text %}
    <div style="padding: 16px 32px; margin: 8px 0 24px;">
      <div style="font-family: 'Playfair Display', Georgia, serif; font-size: 22px; font-style: italic; color: #111e5c; line-height: 1.4; margin-bottom: 10px;">
        {% if featured_quote.video_url %}<a href="{{ featured_quote.video_url }}" style="color: inherit; text-decoration: none;">{% endif %}“{{ featured_quote.text }}”{% if featured_quote.video_url %}</a>{% endif %}
      </div>
      <div style="font-family: -apple-system, sans-serif; font-size: 12px; font-weight: 600; color: #6b7280; letter-spacing: 0.5px;">
        — {{ featured_quote.speaker }}
      </div>
    </div>
    {% endif %}

    {# Prose paragraphs — 2-3 paragraphs telling the fuller story #}
    {% for paragraph in briefing.prose_paragraphs %}
    <p style="font-family: 'Newsreader', Georgia, serif; font-size: 17px; line-height: 1.65; color: #374151; margin: 0 0 18px 0;">
      {{ paragraph }}
    </p>
    {% endfor %}

    {# Sources & Resources block #}
    {% if briefing.external_resources or briefing.video_deep_link %}
    <div style="padding: 14px 18px; background: #f5f3ff; border: 1px solid #c4b5fd; border-radius: 4px; margin-top: 24px;">
      <div style="font-family: -apple-system, sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 2px; color: #5b21b6; margin-bottom: 6px;">
        SOURCES & RESOURCES
      </div>
      <div style="font-family: -apple-system, sans-serif; font-size: 12px; font-weight: 600; line-height: 1.6; color: #2f4ac7;">
        {% for res in briefing.external_resources %}
          {% if res.url %}
            <a href="{{ res.url }}" style="color: #2f4ac7; text-decoration: none;">↗ {{ res.title }}</a>
          {% else %}
            ↗ {{ res.title }}
          {% endif %}
          {% if not loop.last %} · {% endif %}
        {% endfor %}
        {% if briefing.video_deep_link %}
          {% if briefing.external_resources %} · {% endif %}
          <a href="{{ briefing.video_deep_link }}" style="color: #2f4ac7; text-decoration: none;">Watch the briefing ↗</a>
        {% endif %}
      </div>
    </div>
    {% endif %}
  </div>
  {% endfor %}

  {# Questions raised — compact list #}
  {% if analysis.questions_raised %}
  <div style="margin: 32px 0;">
    <div style="font-family: -apple-system, sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 2px; color: #3b5bdb; margin-bottom: 10px;">
      QUESTIONS COUNCIL RAISED
    </div>
    <ul style="font-family: 'Newsreader', Georgia, serif; font-size: 15px; line-height: 1.6; color: #374151; padding-left: 20px; margin: 0;">
      {% for q in analysis.questions_raised %}
      <li style="margin-bottom: 8px;">{{ q }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  {% set schedule_link_label = "View upcoming City Council study sessions" %}
  {% include "_footer.html.j2" %}

</div>
