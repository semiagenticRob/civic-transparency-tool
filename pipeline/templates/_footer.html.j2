{# Footer partial — subscribe CTA + colophon with schedule link.
   Context: newsletter (dict), formatted_date (str), schedule_portal_url (str),
            schedule_link_label (str), meeting_video_url (str | None). #}
<div style="text-align: center; padding: 40px 32px; background: #111e5c; margin-top: 40px; border-radius: 4px;">
  <div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 2px; color: #dde6ff; margin-bottom: 12px;">
    DELIVERED EVERY WEDNESDAY
  </div>
  <div style="font-family: 'Playfair Display', Georgia, 'Times New Roman', serif; font-size: 22px; font-weight: 700; color: #ffffff; line-height: 1.3; margin-bottom: 20px;">
    Forward this to a neighbor who pays attention.
  </div>
  {% if newsletter.subscribe_url %}
  <a href="{{ newsletter.subscribe_url }}" style="display: inline-block; padding: 12px 28px; background: #ffffff; color: #111e5c; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 14px; font-weight: 700; text-decoration: none; border-radius: 6px;">
    Subscribe to {{ newsletter.name }}
  </a>
  {% endif %}
</div>

<div style="text-align: center; padding: 24px 0 8px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 2px; color: #9ca3af;">
  {{ newsletter.name|upper }} · {{ formatted_date }}
</div>
{% if schedule_portal_url %}
<div style="text-align: center; padding: 4px 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.5px;">
  <a href="{{ schedule_portal_url }}" style="color: #2f4ac7; text-decoration: none;">{{ schedule_link_label }} ↗</a>
</div>
{% endif %}
<div style="text-align: center; padding: 4px 0; font-family: 'Newsreader', Georgia, 'Times New Roman', serif; font-size: 12px; font-style: italic; color: #9ca3af;">
  Independent, AI-assisted civic journalism. Not affiliated with the City of {{ city.name }}.
</div>
